# Copy to `.env.local` for local dev. On Vercel, add the same keys (no VITE_ prefix difference).

# Supabase → Project Settings → API
# Project URL (no trailing slash)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# "anon" / "publishable" public key (safe for browser) — use either name:
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# VITE_SUPABASE_ANON_KEY=same_value_as_above

# Optional: only if your URL is NOT *.supabase.co (e.g. custom domain)
# VITE_SUPABASE_PROJECT_ID=your_project_ref

# Optional features
# VITE_GOOGLE_MAPS_API_KEY=
# VITE_TEAM_CONTACT_EMAIL=
