# Copy to `.env.local` for local dev. On Vercel, add the same keys (no VITE_ prefix difference).

# Supabase → Project Settings → API
# Project URL (no trailing slash) — VANO production example:
# VITE_SUPABASE_URL=https://puomfwjtpvqedwxjxogh.supabase.co

# Publishable key (Dashboard → API) or legacy JWT anon key — same access level:
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Optional: explicit project ref for Edge Function URLs (otherwise parsed from VITE_SUPABASE_URL)
# VITE_SUPABASE_PROJECT_ID=puomfwjtpvqedwxjxogh

# Canonical public URL (canonical tags, OG URLs, password-reset redirect). Use https://vanojobs.com in production.
# VITE_SITE_URL=https://vanojobs.com

# Optional: canonical site for OAuth / password-reset redirects (Supabase allow list). OTP sign-up does not use this.
# VITE_AUTH_EMAIL_REDIRECT_URL=https://vanojobs.com

# Optional features
# VITE_GOOGLE_MAPS_API_KEY=
# VITE_TEAM_CONTACT_EMAIL=

# PostHog — product analytics (funnels, retention, session replay).
# The token is write-only + safe to ship to the client per PostHog docs.
# If either is unset, the SDK no-ops and events still flow to the existing
# `analytics_events` table in Supabase.
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry — automatic error + crash reporting. Get the DSN from
# sentry.io → Project Settings → Client Keys (DSN). If unset the SDK
# no-ops, so dev boxes without the var don't spam the production
# Sentry project with noise.
# VITE_SENTRY_DSN=

# Optional: second gate for /admin UI (you must still have admin role in user_roles)
# VITE_ADMIN_PAGE_PASSWORD=

# Optional: comma-separated list of emails that may see cosmetic admin
# affordances (the /admin nav link + admin-only delete buttons on the
# talent board). Does NOT grant admin authority — server-side user_roles
# checks enforce that. Lets staging/preview envs use test emails without
# a code change. Falls back to the baked-in defaults when unset.
# VITE_ADMIN_OWNER_EMAILS=founder@example.com,cofounder@example.com

# Supabase Edge Functions → Secrets (Dashboard → Edge Functions → Manage secrets).
# These are set on Supabase, NOT on Vercel. Client code never reads them.

# Transactional email (Resend)
# LISTING_NOTIFY_EMAIL=vano1app@gmail.com
# RESEND_API_KEY=re_...                       # RESEND_FROM must be a verified sender/domain in Resend
# RESEND_FROM=VANO <onboarding@resend.dev>
# SITE_URL=https://vanojobs.com               # Used in email links + Stripe redirect_urls

# AI providers
# GEMINI_API_KEY=                             # Google Gemini — ai-cover-letter, ai-find-*, ai-job-description, ai-pricing-advisor, ai-profile-coach, ai-review-summary, smart-match-jobs, vano-assistant. Get at https://aistudio.google.com/app/apikey (free tier, 15 rpm)
# ANTHROPIC_API_KEY=                          # improve-community-bio
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# SERPER_API_KEY=                             # Web search for ai-find-freelancer + ai-find-retry

# Stripe (Connect + Checkout for AI Find and Vano Pay)
# STRIPE_SECRET_KEY=sk_live_...               # Platform secret key; never commit
# STRIPE_PUBLISHABLE_KEY=pk_live_...          # Optional — only if a future edge fn needs it
# STRIPE_WEBHOOK_SECRET=whsec_...             # Signing secret for stripe-webhook HMAC verification

# AI Find Payment Link (client-side redirect, bypasses create-ai-find-checkout edge fn).
# Create in Stripe Dashboard → Payment Links → €1 "Vano AI Find", success URL = /ai-find-return.
# VITE_STRIPE_AI_FIND_PAYMENT_LINK=https://buy.stripe.com/...

# Web Push (VAPID — Push notifications for new messages / hire requests)
# Generate once with `npx web-push generate-vapid-keys` and paste below.
# VAPID_PUBLIC_KEY=                           # Also returned by get-vapid-key to the frontend for subscription registration
# VAPID_PRIVATE_KEY=

# Edge function CORS allowlist (optional; defaults to vanojobs.com + previews)
# ALLOWED_ORIGINS=https://vanojobs.com,https://www.vanojobs.com
