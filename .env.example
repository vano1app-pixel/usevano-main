# Copy to `.env.local` for local dev. On Vercel, add the same keys (no VITE_ prefix difference).

# Supabase → Project Settings → API
# Project URL (no trailing slash)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# "anon" / "publishable" public key (safe for browser) — use either name:
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# VITE_SUPABASE_ANON_KEY=same_value_as_above

# Optional: only if your URL is NOT *.supabase.co (e.g. custom domain)
# VITE_SUPABASE_PROJECT_ID=your_project_ref

# Optional: production site URL for docs / future canonical links (not required; app uses current host)
# VITE_SITE_URL=https://vanojobs.com

# Optional: canonical site for OAuth / password-reset redirects (Supabase allow list). OTP sign-up does not use this.
# VITE_AUTH_EMAIL_REDIRECT_URL=https://vanojobs.com

# Optional features
# VITE_GOOGLE_MAPS_API_KEY=
# VITE_TEAM_CONTACT_EMAIL=

# Supabase Edge Function: notify-community-listing-request (set in Supabase → Edge Functions → Secrets)
# RESEND_API_KEY=
# LISTING_NOTIFY_EMAIL=vano1app@gmail.com
# RESEND_FROM=VANO <onboarding@resend.dev>
# SITE_URL=https://vanojobs.com
